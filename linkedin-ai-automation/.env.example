# Server
PORT=3000
NODE_ENV=development

# AI provider: gemini | openai (defaults to gemini if GEMINI_API_KEY is set)
AI_PROVIDER=gemini

# Google Gemini — generate LinkedIn post copy (recommended, free tier available)
# Get key: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# OpenAI — optional alternative
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# Cloudinary — image uploads
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Composio — LinkedIn publishing (MCP + Composio)
# Get your key: https://platform.composio.dev/settings
COMPOSIO_API_KEY=your_composio_api_key
COMPOSIO_USER_ID=default
LINKEDIN_TOOLKIT_VERSION=20260424_00

# Optional: set author URN manually (from LINKEDIN_GET_MY_INFO)
# Example: urn:li:person:AbCdEfGh
LINKEDIN_AUTHOR_URN=

# Set to "true" to simulate publish without calling LinkedIn (for local testing)
# false = real LinkedIn posts via Composio | true = test only
MOCK_LINKEDIN_PUBLISH=false
